# Chemin vers les données atlas (cache sunlight, processed, raw)
# Utiliser un chemin hors repo pour éviter la charge du filewatcher en dev
# Windows  : set MAPPY_DATA_ROOT=D:\mappy-hour-data
# Linux    : export MAPPY_DATA_ROOT=/data/mappy-hour
MAPPY_DATA_ROOT=

# Mode "cache uniquement" — runtime, sans rebuild.
# true sur tout serveur sans GPU (Mitch etc.) :
#   - les routes /api/sunlight/{point,instant/stream} retournent 503
#   - la route timeline force cacheOnly=true côté serveur
#   - le client (via prop server-rendered) skip les diagnostics au click
# Architecture immuable : la même image Docker/le même build sert avec ou sans GPU.
MAPPY_FORCE_CACHE_ONLY=false

# Optionnel : token GitHub pour télécharger les atlas depuis une release privée
# GITHUB_TOKEN=ghp_xxx

# Chemin host du cache atlas, monté en bind dans le container (docker-compose.yml).
# Defaults à ./data/cache/sunlight pour le dev local.
# Sur mitch (WSL2 → Windows path) : MAPPY_ATLAS_PATH=/mnt/c/mappy-data/cache/sunlight
# MAPPY_ATLAS_PATH=./data/cache/sunlight
