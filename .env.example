# Chemin vers les données atlas (cache sunlight, processed, raw)
# Utiliser un chemin hors repo pour éviter la charge du filewatcher en dev
# Windows  : set MAPPY_DATA_ROOT=D:\mappy-hour-data
# Linux    : export MAPPY_DATA_ROOT=/data/mappy-hour
MAPPY_DATA_ROOT=

# Mode "cache uniquement" côté serveur (runtime, sans rebuild).
# true → la route /api/sunlight/timeline/stream ignore le paramètre client et force cacheOnly.
# Recommandé sur tout serveur sans GPU (Mitch etc.) — évite les tentatives de calcul à la volée
# qui échouent faute de zenith mask (grid metadata).
MAPPY_FORCE_CACHE_ONLY=false

# Mode "cache uniquement" côté UI (inliné au moment du `pnpm build`).
# true → masque le bouton "cache uniquement" dans l'interface et l'active par défaut.
# ATTENTION : NEXT_PUBLIC_* doit être défini AVANT la compilation.
NEXT_PUBLIC_FORCE_CACHE_ONLY=false

# Optionnel : token GitHub pour télécharger les atlas depuis une release privée
# GITHUB_TOKEN=ghp_xxx
