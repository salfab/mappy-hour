# Dépendances locales (reconstruites dans le conteneur)
node_modules

# Données lourdes — non incluses dans l'image (volume ou atlas:download au runtime)
data/
dist/releases/

# Exception : les fichiers places sont BAKED dans l'image (Posture 4).
