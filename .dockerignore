.worktrees/
bench-tile-first-results-*/
scripts/bench-tile-first-results-*/

# Environnement
.env
.env.local
.env.production.local

# Éditeurs / OS
.DS_Store
Thumbs.db
*.swp

# Git
.git
.gitignore
