{
  "name": "mappy-hour",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.0.6",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "benchmark:precompute:lausanne": "tsx scripts/benchmark/precompute-lausanne-benchmark.ts",
    "benchmark:parallax:nyon": "tsx scripts/benchmark/nyon-parallax-impact.ts",
    "benchmark:horizon:macro:lausanne": "tsx scripts/benchmark/lausanne-horizon-macro-tiling.ts",
    "benchmark:horizon:tile-vs-global:lausanne": "tsx scripts/benchmark/lausanne-horizon-tile-vs-global.ts",
    "benchmark:cache:warm": "tsx scripts/benchmark/precomputed-cache-hit-vs-warm.ts",
    "benchmark:precompute:cpu:lots": "tsx scripts/benchmark/precompute-cpu-lots-benchmark.ts",
    "benchmark:precompute:cpu:breakdown": "tsx scripts/benchmark/profile-precompute-cpu-breakdown.ts",
    "benchmark:precompute:workers": "tsx scripts/benchmark/precompute-workers-parallelism.ts",
    "precompute:region": "tsx scripts/precompute/precompute-region-sunlight.ts",
    "precompute:lausanne:terraces:next-weekends": "tsx scripts/precompute/precompute-lausanne-terraces-next-two-weekends.ts",
    "cache:verify": "tsx scripts/precompute/manage-sunlight-cache.ts --action=verify",
    "cache:purge": "tsx scripts/precompute/manage-sunlight-cache.ts --action=purge",
    "ingest:lausanne:buildings": "tsx scripts/ingest/download-lausanne-buildings.ts",
    "ingest:lausanne:terrain:ch": "tsx scripts/ingest/download-lausanne-terrain-ch.ts",
    "ingest:lausanne:vegetation:surface": "tsx scripts/ingest/download-lausanne-vegetation-surface.ts",
    "ingest:lausanne:terrain:horizon": "tsx scripts/ingest/download-lausanne-horizon-dem.ts",
    "ingest:lausanne:places": "tsx scripts/ingest/download-lausanne-places-osm.ts",
    "ingest:nyon:buildings": "tsx scripts/ingest/download-nyon-buildings.ts",
    "ingest:nyon:terrain:ch": "tsx scripts/ingest/download-nyon-terrain-ch.ts",
    "ingest:nyon:vegetation:surface": "tsx scripts/ingest/download-nyon-vegetation-surface.ts",
    "ingest:nyon:terrain:horizon": "tsx scripts/ingest/download-nyon-horizon-dem.ts",
    "ingest:nyon:places": "tsx scripts/ingest/download-nyon-places-osm.ts",
    "ingest:lausanne": "pnpm run ingest:lausanne:buildings && pnpm run ingest:lausanne:terrain:ch && pnpm run ingest:lausanne:vegetation:surface && pnpm run ingest:lausanne:terrain:horizon && pnpm run ingest:lausanne:places",
    "ingest:nyon": "pnpm run ingest:nyon:buildings && pnpm run ingest:nyon:terrain:ch && pnpm run ingest:nyon:vegetation:surface && pnpm run ingest:nyon:terrain:horizon && pnpm run ingest:nyon:places",
    "ingest:all": "pnpm run ingest:lausanne && pnpm run ingest:nyon",
    "preprocess:buildings:index": "tsx scripts/preprocess/build-lausanne-buildings-index.ts",
    "preprocess:horizon:mask": "tsx scripts/preprocess/build-lausanne-horizon-mask.ts",
    "preprocess": "pnpm run preprocess:buildings:index && pnpm run preprocess:horizon:mask",
    "fetch:lausanne:3d": "pnpm run ingest:lausanne:buildings && pnpm run ingest:lausanne:terrain:ch && pnpm run ingest:lausanne:vegetation:surface && pnpm run ingest:lausanne:terrain:horizon && pnpm run preprocess",
    "fetch:nyon:3d": "pnpm run ingest:nyon:buildings && pnpm run ingest:nyon:terrain:ch && pnpm run ingest:nyon:vegetation:surface && pnpm run ingest:nyon:terrain:horizon && pnpm run preprocess:buildings:index",
    "fetch:all:models": "pnpm run ingest:all && pnpm run preprocess",
    "setup:lausanne": "pnpm run ingest:lausanne && pnpm run preprocess",
    "setup:nyon": "pnpm run ingest:nyon && pnpm run preprocess",
    "setup:all": "pnpm run fetch:all:models",
    "setup": "pnpm run setup:all"
  },
  "dependencies": {
    "@types/d3-contour": "^3.0.6",
    "adm-zip": "^0.5.16",
    "d3-contour": "^4.0.2",
    "earcut": "^3.0.2",
    "geotiff": "^3.0.4",
    "gl": "^8.1.6",
    "leaflet": "^1.9.4",
    "next": "16.1.6",
    "polygon-clipping": "^0.15.7",
    "proj4": "^2.20.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "suncalc": "^1.9.0",
    "webgpu": "^0.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/adm-zip": "^0.5.7",
    "@types/earcut": "^3.0.0",
    "@types/gl": "^6.0.5",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/suncalc": "^1.9.2",
    "@webgpu/types": "^0.1.69",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "playwright": "^1.58.2",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
